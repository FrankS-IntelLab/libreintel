{
  "manifest_version": 3,
  "name": "LibreIntel",
  "version": "0.7.1",
  "description": "Your intelligent reading & research companion — capture text, build exploration trees, and chat with AI",
  "permissions": ["sidePanel", "activeTab", "contextMenus", "storage", "scripting"],
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "commands": {
    "voice-input": {
      "suggested_key": { "default": "Ctrl+1", "mac": "Command+1" },
      "description": "Start voice input"
    }
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "optional_permissions": [],
  "host_permissions": ["<all_urls>"]
}
