{
  "manifest_version": 3,
  "name": "LibreIntel",
  "version": "0.5.0",
  "description": "Your intelligent reading & research companion — capture text, build exploration trees, and chat with AI",
  "permissions": ["sidePanel", "activeTab", "contextMenus", "storage", "scripting"],
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {},
  "optional_permissions": [],
  "host_permissions": ["<all_urls>"]
}
